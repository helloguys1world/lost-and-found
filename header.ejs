<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lost & Found Management</title>
    <!-- Google Fonts for Modern Typography -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav>
    <div class="brand"><a href="/" style="color: inherit; text-decoration: none;">Lost&Found</a></div>
    <div class="links">
        <a href="/feed">Public Feed</a>
        <% if (user) { %>
            <a href="/announcements" style="position: relative;">
                Announcements
                <% if (typeof unreadNotifications !== 'undefined' && unreadNotifications > 0) { %>
                    <span style="background: red; color: white; border-radius: 50%; padding: 2px 6px; font-size: 0.75rem; position: absolute; top: -5px; right: -10px;"><%= unreadNotifications %></span>
                <% } %>
            </a>
            <a href="/dashboard">Dashboard</a>
            <% if (user.role !== 'admin') { %>
                <a href="/report-lost">Report Lost</a>
                <a href="/report-found">Report Found</a>
            <% } %>
            <% if (user.role === 'admin') { %>
                <a href="/admin/dashboard">Admin Dashboard</a>
            <% } %>
            <a href="/logout" class="btn btn-secondary" style="padding: 0.5rem 1rem;">Logout (<%= user.username %>)</a>
        <% } else { %>
            <a href="/login">Login</a>
            <a href="/signup" class="btn" style="padding: 0.5rem 1rem;">Sign Up</a>
        <% } %>
    </div>
</nav>

<div class="container">
