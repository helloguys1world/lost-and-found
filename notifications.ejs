<%- include('partials/header') %>

<div class="card" style="max-width: 800px; margin: 0 auto;">
    <h2 style="margin-bottom: 1.5rem;">Notifications</h2>
    
    <% if (notifications.length === 0) { %>
        <p style="text-align: center; color: var(--text-muted); padding: 2rem;">You have no notifications.</p>
    <% } else { %>
        <ul style="list-style: none; padding: 0;">
            <% notifications.forEach(notif => { %>
                <li style="border-bottom: 1px solid var(--border-color); padding: 1rem; <%= notif.is_read ? 'opacity: 0.7;' : 'background-color: rgba(0, 122, 255, 0.05);' %>">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                        <strong><%= notif.type ? notif.type.toUpperCase() : 'ALERT' %></strong>
                        <span style="font-size: 0.8rem; color: var(--text-muted);"><%= new Date(notif.created_at).toLocaleString() %></span>
                    </div>
                    <p style="margin: 0;"><%= notif.message %></p>
                </li>
            <% }) %>
        </ul>
    <% } %>
</div>

<%- include('partials/footer') %>
